datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id        String   @id @default(uuid())
  name      String   // Example: "Coding Channel", "Personal Vlogs"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts    Post[]
  sessions SocialSession[]
}

model SocialSession {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform    String   // YOUTUBE, TIKTOK, INSTAGRAM, FACEBOOK, THREADS, LINKEDIN
  sessionData Json     // Encrypted Playwright storageState context cookies JSON
  updatedAt   DateTime @updatedAt

  @@index([profileId])
}

model Post {
  id              String   @id @default(uuid())
  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cloudinaryUrl   String   @db.Text
  platform        String   // YOUTUBE_SHORTS, YOUTUBE_LONG, TIKTOK, INSTA_REELS, FB_REELS, THREADS, LINKEDIN
  title           String?  @db.Text
  description     String?  @db.Text
  scheduledAt     DateTime // Execution point timestamp
  status          Status   @default(PENDING)
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([profileId])
}

enum Status {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}
